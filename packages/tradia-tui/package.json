{
  "name": "tradia",
  "version": "0.1.1",
  "description": "Terminal AI market intelligence assistant for traders.",
  "type": "module",
  "license": "MIT",
  "author": "Talocode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talocode/tradia.git",
    "directory": "packages/tradia-tui"
  },
  "homepage": "https://github.com/talocode/tradia#tradiaai-tui",
  "bugs": {
    "url": "https://github.com/talocode/tradia/issues"
  },
  "keywords": [
